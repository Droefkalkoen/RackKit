# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Blender extension build output
/dist/
*.zip

# Blender backup files
*.blend1
*.blend2

# Vendored RE SDK (Reason Studios, "All rights reserved") — not redistributable
# under GPL-3.0, and the SDK license forbids pairing it with copyleft software.
# Kept locally for reference only; nothing here ships in the extension.
# Exceptions: the acceptance testing checklist (reference material) and the SDK
# license agreement (kept alongside so its terms travel with retained material).
/SDK_v4.6.0/*
!/SDK_v4.6.0/Documentation/
/SDK_v4.6.0/Documentation/*
!/SDK_v4.6.0/Documentation/acceptance_testing_checklist.txt
!/SDK_v4.6.0/Licenses/
/SDK_v4.6.0/Licenses/*
!/SDK_v4.6.0/Licenses/RE SDK License Agreement.txt
